# ── Required ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Get from https://console.anthropic.com

# ── Database ──────────────────────────────────────────────────────────────
PIPELINE_DB_PATH=data/sentinel.db    # SQLite file path (created automatically)

# ── Agent tuning ──────────────────────────────────────────────────────────
REFLECTION_MODEL=claude-sonnet-4-5   # Claude model used by all agents
MAX_RETRY_ATTEMPTS=3                 # Max remediation retries before escalating
MONITOR_POLL_INTERVAL_SECONDS=5      # (future use)
LOG_LEVEL=INFO

# ── LangSmith distributed tracing (Prompt 6) ──────────────────────────────
# Get your API key at https://smith.langchain.com → Settings → API Keys
# Set LANGCHAIN_TRACING_V2=true to enable; omit or set false to disable (no-op)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...            # Replace with your LangSmith API key
LANGCHAIN_PROJECT=pipeline-sentinel  # Project name shown in LangSmith UI

# ── Airflow integration (set USE_AIRFLOW=true to connect a real Airflow) ──
USE_AIRFLOW=false
AIRFLOW_URL=http://localhost:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow
