# ── Required ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Get from https://console.anthropic.com

# ── Database ──────────────────────────────────────────────────────────────
PIPELINE_DB_PATH=data/sentinel.db    # SQLite file path (created automatically)

# ── Agent tuning ──────────────────────────────────────────────────────────
REFLECTION_MODEL=claude-sonnet-4-5   # Claude model used by all agents
MAX_RETRY_ATTEMPTS=3                 # Max remediation retries before escalating
MONITOR_POLL_INTERVAL_SECONDS=5      # (future use)
LOG_LEVEL=INFO

# ── LangSmith distributed tracing (Prompt 6) ──────────────────────────────
# Get your API key at https://smith.langchain.com → Settings → API Keys
# Set LANGCHAIN_TRACING_V2=true to enable; omit or set false to disable (no-op)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...            # Replace with your LangSmith API key
LANGCHAIN_PROJECT=pipeline-sentinel  # Project name shown in LangSmith UI

# ── Airflow integration (set USE_AIRFLOW=true to connect a real Airflow) ──
USE_AIRFLOW=false
AIRFLOW_URL=http://localhost:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# ── Autonomous watcher (python -m watcher.sentinel_watcher) ───────────────
# Comma-separated DAG IDs to watch. Leave empty to run proactive checks only.
WATCHER_DAG_IDS=retail_pipeline,retail_streaming_pipeline
# How often to poll Airflow for new failed runs (seconds)
WATCHER_POLL_INTERVAL_SECONDS=300
# How often to run freshness + row count proactive checks (seconds)
WATCHER_PROACTIVE_INTERVAL_SECONDS=900
# Maximum age of last successful run before freshness alert fires (hours)
FRESHNESS_MAX_AGE_HOURS=6
# Row count deviation % that triggers a proactive anomaly (0.20 = 20%)
ROW_COUNT_THRESHOLD_PCT=0.20

# ── Webhook server (uvicorn watcher.webhook_server:app --port 8765) ───────
# Port the FastAPI webhook server listens on
WEBHOOK_PORT=8765

# ── Slack alerting ────────────────────────────────────────────────────────
# Incoming Webhook URL from https://api.slack.com/messaging/webhooks
# Leave empty to disable Slack alerts
SLACK_WEBHOOK_URL=
